# ── ClassPulse Environment Variables ──
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/classpulse

# JWT secret key — use a long random string (required)
JWT_SECRET=change_me_to_a_random_secret_key

# JWT token expiry (optional, default: 8h)
JWT_EXPIRES_IN=8h

# Server port (optional, default: 5000)
PORT=5000

# ── SMTP (email sending) ──
# If unset, emails will be sent via Ethereal (dev-only, preview URLs in console)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
FROM_EMAIL=classpulse@noreply.com

# Frontend URL for reset-password links (optional, default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Environment (optional, sets "test" for test mode)
NODE_ENV=development
